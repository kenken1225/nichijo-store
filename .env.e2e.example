# E2E（Playwright）用。コピーして .env.e2e を作る: cp .env.e2e.example .env.e2e
# または .env.local に同じキーを書いても読み込まれます（.env.e2e の方が後から読み込まれ上書き）

# テスト対象のオリジン（末尾スラッシュなし）
E2E_BASE_URL=https://nichijo-jp.com

# ストアフロントがパスワード保護のときのみ必要（.env.e2e に実値を書く）
E2E_STOREFRONT_PASSWORD=

# トップのフィーチャーから辿る商品名（リンクの accessible name にマッチ）
E2E_FEATURED_PRODUCT_NAME=TEST6
